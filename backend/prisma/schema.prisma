generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String

  urls      Url[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Url {
  id          String   @id @default(cuid())
  shortCode   String   @unique
  originalUrl String

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}